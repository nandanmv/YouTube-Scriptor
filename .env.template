# AI Model Configuration
DEFAULT_MODEL=openai/gpt-4o

# Per-Task Models (optional - falls back to DEFAULT_MODEL)
ANGLE_MODEL=openai/gpt-4o
RESEARCH_MODEL=openai/gpt-4o-mini
SCRIPT_MODEL=openai/gpt-4o
QUALITY_MODEL=anthropic/claude-3-5-sonnet-20250620

# Legacy support (mapped to DEFAULT_MODEL)
AI_MODEL=openai/gpt-4o

# API Keys
OPENAI_API_KEY=your_openai_key
GEMINI_API_KEY=your_gemini_key
ANTHROPIC_API_KEY=your_anthropic_key
YOUTUBE_API_KEY=your_youtube_data_api_v3_key
# Optional: bypass YouTube IP blocks on transcript fetching (use one or both)
# Option A: path to Netscape-format cookies.txt exported from your browser
# YOUTUBE_COOKIES_FILE=/path/to/cookies.txt
# Option B: read cookies directly from an installed browser (chrome, firefox, safari, edge)
# YOUTUBE_COOKIES_BROWSER=safari

# Google Custom Search API (for web research)
GOOGLE_SEARCH_API_KEY=your_google_api_key_here
GOOGLE_SEARCH_ENGINE_ID=your_search_engine_id_here

# Quality Control
QUALITY_THRESHOLD=90
MAX_REGENERATIONS=3

# Quick Script Settings (optional)
# QUICK_SCRIPT_READING_LEVEL=10th grade
# QUICK_SCRIPT_TARGET_AUDIENCE=business person
# QUICK_SCRIPT_MAX_ITERATIONS=3

# Web App Login
# Set these before deploying the FastAPI app publicly
APP_LOGIN_PASSWORD=change_this_before_deploy
APP_SESSION_SECRET=use_a_long_random_secret_here
# APP_SESSION_TTL_HOURS=24
# APP_COOKIE_SECURE=true
# APP_COOKIE_NAME=yt_strategy_session
